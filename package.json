{
  "name": "resume-ai-rag",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "prepare:resumes": "ts-node-dev --transpile-only scripts/prepareResumes.ts",
    "push:resumes": "ts-node-dev --transpile-only scripts/pushResumes.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "jest --passWithNoTests",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "mongodb": "^4.12.1",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "undici": "^5.22.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.19",
    "@types/jest": "^29.5.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.5.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.61.0",
    "@typescript-eslint/parser": "^5.61.0",
    "eslint": "^8.44.0",
    "eslint-config-prettier": "^8.8.0",
    "jest": "^29.6.0",
    "prettier": "^2.8.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}
