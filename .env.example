# Application Settings
NODE_ENV=development
APP_NAME=resume-ai-rag
APP_VERSION=0.1.0
PORT=3000
LOG_LEVEL=info

# Request & Response Settings
REQUEST_SIZE_LIMIT=100kb
TOPK_RERANK=10

# MongoDB Configuration
MONGODB_URI=
MONGODB_DB_NAME=db_resume
MONGODB_COLLECTION_NAME=resume
MONGODB_BM25_INDEX=bm25_index
MONGODB_VECTOR_INDEX=vector_index

# Mistral Embedding API (DO NOT COMMIT REAL KEYS)
MISTRAL_API_KEY=
MISTRAL_EMBED_MODEL=mistral-embed
MISTRAL_EMBED_DIMENSION=1024

# GROQ LLM API
GROQ_API_KEY=
GROQ_LLM_MODEL=meta-llama/llama-3.1-70b-versatile

# Optional: Search Configuration
SEARCH_BM25_TOP_K=20
SEARCH_VECTOR_TOP_K=20
SEARCH_RERANK_TOP_K=10
# Application Settings
NODE_ENV=development
APP_NAME=resume-ai-rag
APP_VERSION=0.1.0
PORT=3000
LOG_LEVEL=info

# Request & Response Settings
REQUEST_SIZE_LIMIT=100kb
TOPK_RERANK=10

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=resume_ai_rag
MONGODB_COLLECTION_NAME=resumes
MONGODB_BM25_INDEX=bm25_index
MONGODB_VECTOR_INDEX=vector_index

# Mistral Embedding API
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_EMBED_MODEL=mistral-embed
MISTRAL_EMBED_DIMENSION=1024

# GROQ LLM API
GROQ_API_KEY=your_groq_api_key_here
GROQ_LLM_MODEL=meta-llama/llama-3.1-70b-versatile

# Optional: Search Configuration
SEARCH_BM25_TOP_K=20
SEARCH_VECTOR_TOP_K=20
SEARCH_RERANK_TOP_K=10
